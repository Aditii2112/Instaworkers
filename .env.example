# --- LLM Runtime (Ollama — Sovereign Sentinel) ---
GEMMA_BASE_URL=http://localhost:11434
GEMMA_MODEL_NAME=sovereign-sentinel

# --- MatFormer Elastic Scaling (S / M / L / XL) ---
MATFORMER_GRANULARITY=auto

# --- InstaBrain Memory ---
INSTABRAIN_DB_PATH=data/instabrain.db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Observability ---
EVENTS_JSONL_PATH=data/events.jsonl

# --- Tool Allowlists ---
TOOL_HTTP_ALLOWLIST=httpbin.org,api.github.com
TOOL_SHELL_ALLOWLIST=ls,cat,head,tail,wc,date,uptime,df,whoami
TOOL_FS_BASE_DIR=data

# --- Contextual Checkpointing ---
CHECKPOINT_ENABLED=true
CHECKPOINT_INTERVAL_CALLS=3

# --- Auditor (State Watchdog) ---
AUDITOR_ENABLED=true

# --- Hybrid Reliability Layer ---
HYBRID_RELIABILITY_ENABLED=true
LOCAL_CONFIDENCE_THRESHOLD=0.8
HIGH_RISK_BUDGET_USD=500
PENDING_RETRY_SECONDS=30
MAX_PENDING_PROCESS_PER_CYCLE=5

# --- Optional Gemini Teacher Validator ---
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-pro
GEMINI_TIMEOUT_SECONDS=20
